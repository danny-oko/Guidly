# Clerk auth (required for GraphQL)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Cloudflare D1 via HTTP (used by `bun run dev` / Next.js local mode)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DATABASE_ID=dcf3868b-834a-4de8-9a46-8bd2f91fafb4
CLOUDFLARE_D1_TOKEN=

# Optional CORS allowlist (default *)
GRAPHQL_ALLOWED_ORIGIN=http://localhost:3004
